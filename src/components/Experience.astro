---
/**
 * Experience Section Component
 * Displays work experience and internships
 */

import { portfolioData } from '../data/portfolio';

const { experience } = portfolioData;

const externalLinkIcon = 'M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14l8.5-8.5';
---

{
  experience.length > 0 && (
    <section id="experience" class="experience section">
      <div class="container">
        <div class="experience__header">
          <h2>Experience</h2>
          <p>My professional journey</p>
        </div>

        <div class="experience__list">
          {experience.map((exp, index) => (
            <div class="experience__card animate-scroll" style=`animation-delay: ${index * 0.1}s`>
              <div class="experience__accent"></div>

              <div class="experience__meta">
                <span class="experience__period">{exp.startDate} - {exp.endDate || 'Present'}</span>
                {exp.current && <span class="experience__current">Current</span>}
              </div>

              <h3 class="experience__role">{exp.role}</h3>

              {exp.companyUrl ? (
                <a
                  href={exp.companyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="experience__company-link"
                >
                  <span>{exp.company}</span>
                  <svg viewBox="0 0 24 24">
                    <path d={externalLinkIcon} />
                  </svg>
                </a>
              ) : (
                <span class="experience__company">{exp.company}</span>
              )}

              <p class="experience__description">{exp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .experience {
    background: linear-gradient(135deg, rgba(10, 15, 30, 0.5), rgba(20, 29, 47, 0.5));
  }

  .experience__header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
    animation: slideInUp 0.6s ease-out;

    h2 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: var(--spacing-md);
      background: var(--gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p {
      font-size: var(--size-lg);
      color: var(--color-text-secondary);
    }
  }

  .experience__list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
    max-width: 700px;
    margin: 0 auto;

    @media (max-width: 768px) {
      gap: var(--spacing-lg);
    }
  }

  .experience__card {
    position: relative;
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    &.visible {
      animation: slideInUp 0.6s ease-out forwards;
    }

    &:hover {
      border-color: var(--color-primary);
      background: rgba(59, 130, 246, 0.05);
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.15);
      transform: translateX(8px);

      @media (max-width: 768px) {
        transform: none;
      }
    }
  }

  .experience__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--gradient-primary);
  }

  .experience__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
  }

  .experience__period {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-primary);
    font-weight: 600;
  }

  .experience__current {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--color-success);
    font-weight: 600;
  }

  .experience__role {
    font-size: var(--size-xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .experience__company-link,
  .experience__company {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--spacing-md);
    transition: all 0.25s ease;
  }

  .experience__company-link {
    cursor: pointer;

    &:hover {
      gap: 0.75rem;
      color: var(--color-primary);
    }

    svg {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .experience__description {
    font-size: var(--size-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
  }
</style>
