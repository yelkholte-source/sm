---
/**
 * Contact Section Component
 * Contact information and functional contact form using formsubmit.co
 */

import { portfolioData } from '../data/portfolio';

const { personal, socialProfiles } = portfolioData;

const icons: Record<string, string> = {
  mail: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M22 6l-10 7L2 6',
  phone: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z',
  map: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z',
  github: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
  linkedin: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  send: 'M22 2L11 13m11-11l-7 20-4-9-9-4 20-7z',
};

function getSvgPath(iconName: string): string {
  return icons[iconName] || icons.send;
}
---

<section id="contact" class="contact section">
  <div class="container">
    <div class="contact__header">
      <h2>Let's Connect</h2>
      <p>Have a question or proposal? I'd love to hear from you!</p>
    </div>

    <div class="contact__content">
      <!-- Contact Information -->
      <div class="contact__info">
        <div class="contact__card animate-scroll">
          <div class="contact__icon-box">
            <svg viewBox="0 0 24 24">
              <path d={getSvgPath('mail')} />
            </svg>
          </div>
          <h3>Email</h3>
          <a href={`mailto:${personal.email}`} class="contact__link">{personal.email}</a>
        </div>

        {
          personal.phone && (
            <div class="contact__card animate-scroll">
              <div class="contact__icon-box">
                <svg viewBox="0 0 24 24">
                  <path d={getSvgPath('phone')} />
                </svg>
              </div>
              <h3>Phone</h3>
              <a href={`tel:${personal.phone}`} class="contact__link">
                {personal.phone}
              </a>
            </div>
          )
        }

        <div class="contact__card animate-scroll">
          <div class="contact__icon-box">
            <svg viewBox="0 0 24 24">
              <path d={getSvgPath('map')} />
            </svg>
          </div>
          <h3>Location</h3>
          <p class="contact__location">{personal.location}</p>
        </div>

        <!-- Social Links -->
        <div class="contact__socials animate-scroll">
          <h4>Connect with me:</h4>
          <div class="contact__social-grid">
            {socialProfiles.map((profile) => (
              <a
                href={profile.url}
                target="_blank"
                rel="noopener noreferrer"
                class="contact__social-link"
                title={profile.name}
              >
                <svg viewBox="0 0 24 24">
                  <path d={getSvgPath(profile.icon)} />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <form id="contact-form" class="contact__form" data-email={personal.email}>
        <div class="contact__form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" placeholder="John Doe" required />
        </div>

        <div class="contact__form-group">
          <label for="email">Your Email</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="john@example.com"
            required
          />
        </div>

        <div class="contact__form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" placeholder="How can I help?" required />
        </div>

        <div class="contact__form-group">
          <label for="message">Message</label>
          <textarea
            id="message"
            name="message"
            placeholder="Your message here..."
            rows="5"
            required></textarea>
        </div>

        <!-- Honeypot field (hidden from users) -->
        <input type="hidden" name="_honeypot" value="" />

        <button type="submit" class="btn btn-primary contact__submit">
          <svg viewBox="0 0 24 24">
            <path d={getSvgPath('send')} />
          </svg>
          <span>Send Message</span>
        </button>
      </form>
    </div>
  </div>
</section>

<!-- Toast Notification -->
<div id="contact-toast" class="contact__toast">
  <div class="contact__toast-content">
    <div class="contact__toast-icon"></div>
    <div class="contact__toast-text">
      <h4 id="toast-title">Message sent!</h4>
      <p id="toast-message">Thank you for contacting me.</p>
    </div>
  </div>
  <button id="toast-close" class="contact__toast-close">
    <svg viewBox="0 0 24 24">
      <path d="M18 6L6 18M6 6l12 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
  <div class="contact__toast-backdrop" id="toast-backdrop"></div>
</div>

<style>
  .contact {
    background: linear-gradient(135deg, rgba(10, 15, 30, 0.5), rgba(20, 29, 47, 0.5));
  }

  .contact__header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
    animation: slideInUp 0.6s ease-out;

    h2 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: var(--spacing-md);
      background: var(--gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p {
      font-size: var(--size-lg);
      color: var(--color-text-secondary);
    }
  }

  .contact__content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-3xl);

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: var(--spacing-2xl);
    }
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .contact__card {
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: all 0.3s ease;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    &.visible {
      animation: slideInUp 0.6s ease-out forwards;
    }

    &:hover {
      border-color: var(--color-primary);
      background: rgba(59, 130, 246, 0.05);
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.15);
      transform: translateY(-4px);
    }

    h3 {
      font-size: var(--size-lg);
      margin-bottom: var(--spacing-md);
      color: var(--color-text);
    }

    p {
      margin: 0;
    }
  }

  .contact__icon-box {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 8px;
    color: var(--color-primary);
    margin: 0 auto var(--spacing-md);
    transition: all 0.3s ease;

    .contact__card:hover & {
      background: rgba(59, 130, 246, 0.2);
      transform: scale(1.1);
    }

    svg {
      width: 24px;
      height: 24px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .contact__link {
    color: var(--color-primary);
    font-weight: 500;
    transition: color 0.25s ease;

    &:hover {
      color: var(--color-accent);
    }
  }

  .contact__location {
    color: var(--color-text-secondary);
    margin: 0;
  }

  .contact__socials {
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    &.visible {
      animation: slideInUp 0.6s ease-out forwards;
    }

    h4 {
      font-size: var(--size-base);
      margin-bottom: var(--spacing-md);
      color: var(--color-text);
    }
  }

  .contact__social-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-md);

    @media (max-width: 480px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .contact__social-link {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-text);
    transition: all 0.25s ease;

    &:hover {
      background: rgba(59, 130, 246, 0.2);
      border-color: var(--color-primary);
      color: var(--color-primary);
      transform: translateY(-2px);
    }

    svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  /* ====== CONTACT FORM ====== */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    padding: var(--spacing-xl);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    animation: slideInUp 0.6s ease-out 0.1s backwards;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    @media (max-width: 768px) {
      padding: var(--spacing-lg);
    }
  }

  .contact__form-group {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .contact__form-group label {
    font-size: var(--size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  .contact__form-group input,
  .contact__form-group textarea {
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--size-base);
    transition: all 0.25s ease;

    html[data-theme='light'] & {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.1);
      color: var(--color-text);
    }

    &::placeholder {
      color: var(--color-text-muted);
    }

    &:focus {
      outline: none;
      background: rgba(59, 130, 246, 0.05);
      border-color: var(--color-primary);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
  }

  .contact__form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__submit {
    width: 100%;
    margin-top: var(--spacing-md);

    svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    &:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }
  }

  /* ====== TOAST NOTIFICATION ====== */
  .contact__toast {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    max-width: 400px;
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.9);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
    opacity: 0;
    pointer-events: none;
    z-index: 1000;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateY(20px) scale(0.95);

    &.show {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0) scale(1);
    }

    html[data-theme='light'] & {
      background: rgba(248, 250, 252, 0.9);
      border-color: rgba(0, 0, 0, 0.1);
    }

    @media (max-width: 640px) {
      bottom: 1rem;
      right: 1rem;
      left: 1rem;
      max-width: none;
    }
  }

  .contact__toast-content {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
  }

  .contact__toast-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-success);

    &.error {
      background: var(--color-error);
    }
  }

  .contact__toast-text h4,
  .contact__toast-text p {
    margin: 0;
  }

  .contact__toast-text h4 {
    font-size: var(--size-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .contact__toast-text p {
    font-size: var(--size-sm);
    color: var(--color-text-secondary);
  }

  .contact__toast-close {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: color 0.25s ease;

    &:hover {
      color: var(--color-text);
    }

    svg {
      width: 100%;
      height: 100%;
      stroke: currentColor;
    }
  }

  .contact__toast-backdrop {
    display: none;

    &.show {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(4px);
      z-index: 999;
    }
  }
</style>

<script>
  /**
   * Contact Form JavaScript
   * Handles form submission with formsubmit.co
   */

  const form = document.getElementById('contact-form');
  const toast = document.getElementById('contact-toast');
  const toastTitle = document.getElementById('toast-title');
  const toastMessage = document.getElementById('toast-message');
  const toastClose = document.getElementById('toast-close');
  const toastBackdrop = document.getElementById('toast-backdrop');

  if (form) {
    const submitBtn = form.querySelector('.contact__submit');
    const originalBtnText = submitBtn.innerHTML;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" opacity="0.3"></circle><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="15.7 47.1" style="animation: spin 0.6s linear infinite"></circle></svg><span>Sending…</span>';

      try {
        const formData = new FormData(form);
        const response = await fetch('https://formsubmit.co/ajax/' + form.dataset.email, {
          method: 'POST',
          body: formData,
        });

        if (response.ok) {
          showToast('Message sent!', 'Thank you for contacting me. I will get back to you soon.', 'success');
          form.reset();
        } else {
          showToast('Error', 'Something went wrong. Please try again.', 'error');
        }
      } catch (error) {
        showToast('Error', 'Failed to send message. Please try again later.', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnText;
      }
    });
  }

  function showToast(title: string, message: string, type: string) {
    toastTitle.textContent = title;
    toastMessage.textContent = message;

    const icon = toast.querySelector('.contact__toast-icon');
    icon.classList.remove('error', 'success');

    if (type === 'error') {
      icon.classList.add('error');
    } else {
      icon.classList.add('success');
    }

    toast.classList.add('show');
    toastBackdrop.classList.add('show');

    setTimeout(() => {
      closeToast();
    }, 5000);
  }

  function closeToast() {
    toast.classList.remove('show');
    toastBackdrop.classList.remove('show');
  }

  toastClose?.addEventListener('click', closeToast);
  toastBackdrop?.addEventListener('click', closeToast);

  // Close toast with Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toast.classList.contains('show')) {
      closeToast();
    }
  });
</script>

<style>
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
