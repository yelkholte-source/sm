---
/**
 * Header Component
 * Sticky navigation with desktop and mobile layouts
 * Features: theme toggle, active link highlighting, mobile drawer menu
 */

import { getActiveNavItems, portfolioData } from '../data/portfolio';

const navItems = getActiveNavItems();
const socialProfiles = portfolioData.socialProfiles;

// Icon mapping
const icons: Record<string, string> = {
  sun: 'M12 3v1m6.364 1.636l-.707-.707M21 12h-1m-1.636 6.364l-.707.707M12 21v-1m-6.364-1.636l.707.707M3 12h1m1.636-6.364l.707-.707',
  moon: 'M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z',
  menu: 'M3 12h18M3 6h18M3 18h18',
  x: 'M18 6L6 18M6 6l12 12',
  home: 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z',
  user: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8z',
  code: 'M16 18l-4-4-4 4M8 6l4 4 4-4',
  book: 'M4 19.5h16M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z',
  briefcase: 'M20 7h-4V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zm-6-2h-4v2h4V5z',
  folder: 'M22 19a2 2 0 0 1-2.41-2.06L17.5 5H2v12a2 2 0 0 0 2 2h16z',
  mail: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M22 6l-10 7L2 6',
  github: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
  linkedin: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  'file-text': 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M16 9H8',
  award: 'M6 9c0-1.1.9-2 2-2h8c1.1 0 2 .9 2 2v8H6V9z M12 5l1.5-3h-3L12 5z M9 18h6',
};

function getSvgPath(iconName: string): string {
  return icons[iconName] || icons.code;
}
---

<header class="header">
  <div class="header__container">
    <a href="#home" class="header__logo">
      <svg viewBox="0 0 24 24" class="header__logo-icon">
        <path d={getSvgPath('code')} />
      </svg>
      <span>{portfolioData.personal.firstName}</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav header__nav--desktop">
      {
        navItems.map((item) => (
          <a href={item.href} class="header__nav-link" data-nav-link={item.href}>
            <svg viewBox="0 0 24 24" class="header__nav-icon">
              <path d={getSvgPath(item.icon)} />
            </svg>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>

    <!-- Right Controls -->
    <div class="header__controls">
      <button class="header__theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <svg viewBox="0 0 24 24" class="header__theme-icon">
          <path d={getSvgPath('sun')} />
        </svg>
      </button>

      <button
        class="header__hamburger"
        id="hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="header__drawer" id="drawer">
    <nav class="header__drawer-nav">
      {
        navItems.map((item) => (
          <a href={item.href} class="header__drawer-link" data-nav-link={item.href}>
            <svg viewBox="0 0 24 24" class="header__drawer-icon">
              <path d={getSvgPath(item.icon)} />
            </svg>
            <span>{item.label}</span>
          </a>
        ))
      }
    </nav>

    <div class="header__drawer-divider"></div>

    <div class="header__drawer-section">
      <div class="header__drawer-label">Connect</div>
      <div class="header__drawer-socials">
        {
          socialProfiles.map((profile) => (
            <a
              href={profile.url}
              target="_blank"
              rel="noopener noreferrer"
              class="header__drawer-social"
              title={profile.name}
            >
              <svg viewBox="0 0 24 24" class="header__drawer-social-icon">
                <path d={getSvgPath(profile.icon)} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>

    <button class="header__drawer-theme" id="drawer-theme-toggle">
      <svg viewBox="0 0 24 24">
        <path d={getSvgPath('sun')} />
      </svg>
      <span>Toggle Theme</span>
    </button>
  </div>

  <div class="header__drawer-backdrop" id="drawer-backdrop"></div>
</header>

<style>
  /* ====== HEADER STRUCTURE ====== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    backdrop-filter: blur(10px);
    background: rgba(10, 15, 30, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 99;
    transition: all 0.3s ease;

    html[data-theme='light'] & {
      background: rgba(248, 250, 252, 0.9);
    }
  }

  .header__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ====== LOGO ====== */
  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    transition: color 0.25s ease;

    &:hover {
      color: var(--color-primary);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 4px;
      border-radius: 4px;
    }
  }

  .header__logo-icon {
    width: 24px;
    height: 24px;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ====== DESKTOP NAVIGATION ====== */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 2rem;

    @media (max-width: 768px) {
      display: none;
    }
  }

  .header__nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.25s ease;
    position: relative;

    &:hover {
      color: var(--color-primary);
    }

    &.active {
      color: var(--color-primary);

      &::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--gradient-primary);
        border-radius: 1px;
      }
    }
  }

  .header__nav-icon {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ====== CONTROLS ====== */
  .header__controls {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .header__theme-toggle {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    color: var(--color-text);

    &:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--color-primary);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    @media (max-width: 768px) {
      display: none;
    }
  }

  .header__theme-icon {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.25s ease;
  }

  /* ====== HAMBURGER MENU ====== */
  .header__hamburger {
    display: none;
    width: 40px;
    height: 40px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;

    &:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--color-primary);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    @media (max-width: 768px) {
      display: flex;
    }

    span {
      width: 20px;
      height: 2px;
      background: var(--color-text);
      border-radius: 1px;
      transition: all 0.3s ease;
    }

    &[aria-expanded='true'] {
      span {
        background: var(--color-primary);

        &:first-child {
          transform: rotate(45deg) translate(8px, 8px);
        }

        &:nth-child(2) {
          opacity: 0;
        }

        &:last-child {
          transform: rotate(-45deg) translate(8px, -8px);
        }
      }
    }
  }

  /* ====== MOBILE DRAWER ====== */
  .header__drawer {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    max-width: 320px;
    height: 100vh;
    background: linear-gradient(135deg, rgba(15, 22, 41, 0.95), rgba(14, 29, 47, 0.95));
    backdrop-filter: blur(10px);
    border-left: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 98;
    transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 5rem 1.5rem 2rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;

    html[data-theme='light'] & {
      background: linear-gradient(135deg, rgba(241, 245, 249, 0.95), rgba(226, 232, 240, 0.95));
    }

    &.open {
      right: 0;
    }

    @media (min-width: 769px) {
      display: none;
    }
  }

  .header__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .header__drawer-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.25s ease;

    &:hover,
    &.active {
      background: rgba(59, 130, 246, 0.1);
      color: var(--color-primary);
    }
  }

  .header__drawer-icon {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .header__drawer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 1rem 0;
  }

  .header__drawer-section {
    margin-bottom: 2rem;
  }

  .header__drawer-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .header__drawer-socials {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .header__drawer-social {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-text);
    transition: all 0.25s ease;

    &:hover {
      background: rgba(59, 130, 246, 0.2);
      border-color: var(--color-primary);
      color: var(--color-primary);
      transform: translateY(-2px);
    }
  }

  .header__drawer-social-icon {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .header__drawer-theme {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: var(--color-text);
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s ease;

    &:hover {
      background: rgba(59, 130, 246, 0.1);
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .header__drawer-backdrop {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    top: 0;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    z-index: -1;
    transition: all 0.3s ease;
    pointer-events: none;

    &.open {
      background: rgba(0, 0, 0, 0.3);
      backdrop-filter: blur(4px);
      pointer-events: all;
      z-index: 50;
    }
  }
</style>

<script>
  /**
   * Header JavaScript - Independent component logic
   * Handles: Mobile menu, theme toggle, active link highlighting
   */

  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const drawerLinks = document.querySelectorAll('.header__drawer-link');
  const desktopNavLinks = document.querySelectorAll('.header__nav-link');
  const themeToggle = document.getElementById('theme-toggle');
  const drawerThemeToggle = document.querySelector('.header__drawer-theme');

  // ====== MOBILE MENU LOGIC ======
  function toggleDrawer() {
    const isOpen = drawer.classList.toggle('open');
    backdrop.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', isOpen);

    if (isOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }

  hamburger?.addEventListener('click', toggleDrawer);
  backdrop?.addEventListener('click', toggleDrawer);

  // Close drawer on link click
  drawerLinks.forEach((link) => {
    link.addEventListener('click', () => {
      drawer.classList.remove('open');
      backdrop.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  // Close drawer on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) {
      toggleDrawer();
    }
  });

  // ====== THEME TOGGLE LOGIC ======
  function initTheme() {
    const savedTheme = localStorage.getItem('theme') || 'dark';
    applyTheme(savedTheme);
  }

  function applyTheme(theme: string) {
    const html = document.documentElement;
    html.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);

    // Update meta theme-color
    const metaThemeColor = document.querySelector('meta[name="theme-color"]');
    if (metaThemeColor) {
      metaThemeColor.setAttribute(
        'content',
        theme === 'dark' ? '#0a0f1e' : '#f8fafc'
      );
    }

    // Update theme toggle icon
    updateThemeIcon(theme);
  }

  function updateThemeIcon(theme: string) {
    const icon = themeToggle?.querySelector('svg path');
    const drawerIcon = drawerThemeToggle?.querySelector('svg path');

    // Sun icon path
    const sunPath = 'M12 3v1m6.364 1.636l-.707-.707M21 12h-1m-1.636 6.364l-.707.707M12 21v-1m-6.364-1.636l.707.707M3 12h1m1.636-6.364l.707-.707';
    // Moon icon path
    const moonPath = "M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z";

    const newPath = theme === 'dark' ? moonPath : sunPath;
    if (icon) icon.setAttribute('d', newPath);
    if (drawerIcon) drawerIcon.setAttribute('d', newPath);
  }

  function toggleTheme() {
    const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    applyTheme(newTheme);
  }

  themeToggle?.addEventListener('click', toggleTheme);
  drawerThemeToggle?.addEventListener('click', toggleTheme);

  // ====== ACTIVE LINK HIGHLIGHTING ======
  function updateActiveLink() {
    const sections = document.querySelectorAll('[id]');
    let current = '';

    sections.forEach((section) => {
      const sectionTop = (section as HTMLElement).offsetTop;
      if (scrollY >= sectionTop - 200) {
        current = section.getAttribute('id') || '';
      }
    });

    // Update desktop nav
    desktopNavLinks.forEach((link) => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
      }
    });

    // Update drawer nav
    drawerLinks.forEach((link) => {
      link.classList.remove('active');
      if (link.getAttribute('href') === `#${current}`) {
        link.classList.add('active');
      }
    });
  }

  window.addEventListener('scroll', updateActiveLink, { passive: true });
  updateActiveLink();

  // Initialize theme on page load
  initTheme();
</script>
