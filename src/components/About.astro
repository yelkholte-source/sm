---
/**
 * About Section Component
 * Displays multi-column description cards with numbering
 */

import { portfolioData } from '../data/portfolio';

const aboutCards = portfolioData.about;
---

<section id="about" class="about section">
  <div class="container">
    <div class="about__header">
      <h2>About Me</h2>
      <p>Get to know me better</p>
    </div>

    <div class="about__grid">
      {
        aboutCards.map((text, index) => (
          <div class="about__card animate-scroll">
            <div class="about__card-accent"></div>
            <div class="about__card-number">{String(index + 1).padStart(2, '0')}</div>
            <p>{text}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about {
    background: linear-gradient(135deg, rgba(10, 15, 30, 0.5), rgba(20, 29, 47, 0.5));
  }

  .about__header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
    animation: slideInUp 0.6s ease-out;

    h2 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: var(--spacing-md);
      background: var(--gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p {
      font-size: var(--size-lg);
      color: var(--color-text-secondary);
    }
  }

  .about__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-xl);

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }

  .about__card {
    position: relative;
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.4);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.5);
    }

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--gradient-primary);
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    &:hover {
      border-color: var(--color-primary);
      background: rgba(59, 130, 246, 0.05);
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.2);
      transform: translateY(-4px);

      &::before {
        opacity: 1;
      }
    }

    @media (max-width: 768px) {
      &.visible {
        animation: slideInUp 0.6s ease-out forwards;
      }
    }
  }

  .about__card-accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--gradient-primary);
    border-radius: 3px;
  }

  .about__card-number {
    font-size: var(--size-4xl);
    font-family: var(--font-mono);
    font-weight: 700;
    color: rgba(59, 130, 246, 0.2);
    margin-bottom: var(--spacing-md);
    line-height: 1;
  }

  .about__card p {
    font-size: var(--size-base);
    line-height: 1.8;
    margin: 0;
    color: var(--color-text-secondary);
  }
</style>
