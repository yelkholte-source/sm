---
/**
 * Skills Section Component
 * Technical skills with categories and soft skills grid
 */

import { portfolioData } from '../data/portfolio';

const { technicalSkills, softSkills } = portfolioData;

// Icon mapping for skill categories
const skillIcons: Record<string, string> = {
  code: 'M16 18l-4-4-4 4M8 6l4 4 4-4',
  globe: 'M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z M3 12h18 M12 3a9 9 0 0 1 0 18 9 9 0 0 0 0-18z',
  tool: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 1 1-3-3l6.91-6.91A6 6 0 0 1 14.7 6.3z',
  message: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  users: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M16 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M23 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z M9 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  lightbulb: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
};

function getSvgPath(iconName: string): string {
  return skillIcons[iconName] || skillIcons.code;
}
---

<section id="skills" class="skills section">
  <div class="container">
    <div class="skills__header">
      <h2>Skills & Expertise</h2>
      <p>Technologies and competencies I've developed</p>
    </div>

    <!-- Technical Skills -->
    <div class="skills__technical">
      {
        technicalSkills.map((skillGroup, index) => (
          <>
            {index > 0 && <div class="skills__divider" />}
            <div class="skills__category animate-scroll">
              <div class="skills__category-header">
                <div class="skills__category-icon">
                  <svg viewBox="0 0 24 24">
                    <path d={getSvgPath(skillGroup.icon)} />
                  </svg>
                </div>
                <h3>{skillGroup.category}</h3>
                <span class="skills__category-count">{skillGroup.skills.length}</span>
              </div>
              <div class="skills__items">
                {skillGroup.skills.map((skill) => (
                  <div class="skills__chip">{skill}</div>
                ))}
              </div>
            </div>
          </>
        ))
      }
    </div>

    {
      softSkills.length > 0 && (
        <>
          <div class="skills__divider skills__divider--large" />

          <div class="skills__soft-intro">
            <h3>Soft Skills</h3>
            <p>Personal qualities that complement my technical expertise</p>
          </div>

          <div class="skills__soft-grid">
            {softSkills.map((skill) => (
              <div class="skills__soft-card animate-scroll">
                <div class="skills__soft-icon">
                  <svg viewBox="0 0 24 24">
                    <path d={getSvgPath(skill.icon)} />
                  </svg>
                </div>
                <h4>{skill.name}</h4>
                <p>{skill.description}</p>
              </div>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>

<style>
  .skills {
    background: linear-gradient(135deg, rgba(10, 15, 30, 0.5), rgba(20, 29, 47, 0.5));
  }

  .skills__header {
    text-align: center;
    margin-bottom: var(--spacing-4xl);
    animation: slideInUp 0.6s ease-out;

    h2 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: var(--spacing-md);
      background: var(--gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p {
      font-size: var(--size-lg);
      color: var(--color-text-secondary);
    }
  }

  /* ====== TECHNICAL SKILLS ====== */
  .skills__technical {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-4xl);
  }

  .skills__divider {
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
    opacity: 0.3;
    margin: var(--spacing-lg) 0;

    &--large {
      margin: var(--spacing-3xl) 0;
    }
  }

  .skills__category {
    padding: var(--spacing-xl);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    &:hover {
      border-color: var(--color-primary);
      box-shadow: 0 0 20px rgba(59, 130, 246, 0.1);
    }

    @media (max-width: 768px) {
      &.visible {
        animation: slideInUp 0.6s ease-out forwards;
      }
    }
  }

  .skills__category-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .skills__category-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 8px;
    color: var(--color-primary);
    transition: all 0.3s ease;

    .skills__category:hover & {
      background: rgba(59, 130, 246, 0.2);
      transform: scale(1.1) rotate(5deg);
    }

    svg {
      width: 24px;
      height: 24px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .skills__category-header h3 {
    flex: 1;
    font-size: var(--size-xl);
    color: var(--color-text);
    margin: 0;
  }

  .skills__category-count {
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
  }

  .skills__items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .skills__chip {
    padding: var(--spacing-xs) var(--spacing-md);
    background: rgba(59, 130, 246, 0.1);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 50px;
    font-size: var(--size-sm);
    color: var(--color-primary);
    font-weight: 500;
    transition: all 0.25s ease;

    &:hover {
      background: rgba(59, 130, 246, 0.15);
      border-color: var(--color-primary);
      transform: translateY(-2px);
    }
  }

  /* ====== SOFT SKILLS ====== */
  .skills__soft-intro {
    text-align: center;
    margin-bottom: var(--spacing-2xl);

    h3 {
      font-size: var(--size-2xl);
      margin-bottom: var(--spacing-md);
      background: var(--gradient-text);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p {
      font-size: var(--size-base);
      color: var(--color-text-secondary);
    }
  }

  .skills__soft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-xl);

    @media (max-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-lg);
    }

    @media (max-width: 480px) {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }

  .skills__soft-card {
    padding: var(--spacing-lg);
    background: rgba(15, 22, 41, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    text-align: center;
    transition: all 0.3s ease;

    html[data-theme='light'] & {
      background: rgba(241, 245, 249, 0.4);
    }

    &:hover {
      border-color: var(--color-accent);
      background: rgba(168, 85, 247, 0.05);
      box-shadow: 0 0 20px rgba(168, 85, 247, 0.1);
      transform: translateY(-4px);
    }

    @media (max-width: 768px) {
      &.visible {
        animation: slideInUp 0.6s ease-out forwards;
      }
    }
  }

  .skills__soft-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 8px;
    color: var(--color-accent);
    margin: 0 auto var(--spacing-lg);
    transition: all 0.3s ease;

    .skills__soft-card:hover & {
      background: rgba(168, 85, 247, 0.2);
      transform: scale(1.1);
    }

    svg {
      width: 24px;
      height: 24px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .skills__soft-card h4 {
    font-size: var(--size-lg);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text);
  }

  .skills__soft-card p {
    font-size: var(--size-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }
</style>
