---
/**
 * Footer Component
 * Brand, quick navigation, socials, and copyright
 */

import { portfolioData, getActiveNavItems } from '../data/portfolio';

const navItems = getActiveNavItems();
const { socialProfiles, personal } = portfolioData;

const icons: Record<string, string> = {
  github: 'M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22',
  linkedin: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  mail: 'M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M22 6l-10 7L2 6',
  code: 'M16 18l-4-4-4 4M8 6l4 4 4-4',
};

function getSvgPath(iconName: string): string {
  return icons[iconName] || icons.code;
}
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand Section -->
      <div class="footer__brand">
        <a href="#home" class="footer__logo">
          <svg viewBox="0 0 24 24">
            <path d={getSvgPath('code')} />
          </svg>
          <span>{personal.firstName} {personal.lastName}</span>
        </a>
        <p class="footer__description">{personal.subtitle}</p>
      </div>

      <!-- Quick Navigation -->
      <div class="footer__nav">
        <h4>Quick Links</h4>
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="footer__link">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect Section -->
      <div class="footer__connect">
        <h4>Connect</h4>
        <div class="footer__socials">
          {socialProfiles.map((profile) => (
            <a
              href={profile.url}
              target="_blank"
              rel="noopener noreferrer"
              class="footer__social"
              title={profile.name}
            >
              <svg viewBox="0 0 24 24">
                <path d={getSvgPath(profile.icon)} />
              </svg>
              <span>{profile.name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer__divider"></div>

    <div class="footer__bottom">
      <p>&copy; 2024 {personal.firstName} {personal.lastName}. All rights reserved.</p>
      <p>
        Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
        &nbsp;•&nbsp;
        Deployed on <a style="display: inline" href="https://vercel.com" target="_blank" rel="noopener noreferrer">Vercel</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: rgba(10, 15, 30, 0.8);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--spacing-4xl) var(--spacing-md);
    margin-top: var(--spacing-4xl);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--spacing-3xl);
    margin-bottom: var(--spacing-3xl);

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: var(--spacing-2xl);
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    transition: color 0.25s ease;
    width: fit-content;

    &:hover {
      color: var(--color-primary);
    }

    svg {
      width: 24px;
      height: 24px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .footer__description {
    font-size: var(--size-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .footer__nav,
  .footer__connect {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);

    h4 {
      font-size: var(--size-base);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text);
      margin: 0;
    }
  }

  .footer__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .footer__link {
    color: var(--color-text-secondary);
    font-size: var(--size-sm);
    transition: all 0.25s ease;
    display: inline-block;

    &:hover {
      color: var(--color-primary);
      transform: translateX(4px);
    }
  }

  .footer__socials {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .footer__social {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-secondary);
    font-size: var(--size-sm);
    transition: all 0.25s ease;
    width: fit-content;

    &:hover {
      color: var(--color-primary);
      transform: translateX(4px);
    }

    svg {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
  }

  .footer__divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    margin-bottom: var(--spacing-xl);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    font-size: var(--size-sm);
    color: var(--color-text-muted);

    @media (max-width: 768px) {
      flex-direction: column;
      text-align: center;
      gap: var(--spacing-md);
    }

    p {
      margin: 0;

      a {
        color: var(--color-primary);
        transition: color 0.25s ease;

        &:hover {
          color: var(--color-accent);
        }
      }
    }
  }
</style>
